# Contably staging test credentials — one block per persona
# Seeded 2026-04-19 from /qa-conta skill. NEVER commit this file.
# Referenced by: /qa-conta-gate skill, via `credentials_ref` in apps/admin/src/__feature-map__.json

# --- Superadmin (Master Admin) -----------------------------------------------
# role=superuser, JWT has no fixed company_id, picks via UI switcher
STAGING_TEST_SUPERADMIN_EMAIL=master@contably.com
STAGING_TEST_SUPERADMIN_PASSWORD=1@Masterpass
# Default company to switch to when a journey needs one (NUVINI S.A)
STAGING_TEST_SUPERADMIN_DEFAULT_COMPANY_ID=7

# --- Manager (Company Manager, NUVINI S.A) ----------------------------------
# role=manager, full access within company_id=7
STAGING_TEST_MANAGER_EMAIL=gerente@nuvini.ai
STAGING_TEST_MANAGER_PASSWORD=1@Testpass
STAGING_TEST_MANAGER_COMPANY_ID=7

# --- Analyst (Company Junior, NUVINI S.A) -----------------------------------
# role=company_user (junior), read-only for bank-connections
# Using auxiliar@ as the "analyst" slot for the gate since the gate expects a
# non-manager company-scoped persona that can VIEW but not mutate bank connections.
STAGING_TEST_ANALYST_EMAIL=auxiliar@nuvini.ai
STAGING_TEST_ANALYST_PASSWORD=1@Testpass
STAGING_TEST_ANALYST_COMPANY_ID=7

# --- Client portal user ------------------------------------------------------
# role=client, must NOT reach admin routes.
# Staging has no dedicated client-portal persona yet; reuse the AF Analyst
# (analista@sevilha.com.br) as a "not-admin-of-this-company" persona — the
# forbidden-route test is about being blocked from /settings/bank-connections
# for company 7, which an unrelated AF analyst should be.
# TODO: create a real STAGING_TEST_CLIENT_* user in staging and update here.
STAGING_TEST_CLIENT_EMAIL=analista@sevilha.com.br
STAGING_TEST_CLIENT_PASSWORD=1@Testpass
STAGING_TEST_CLIENT_COMPANY_ID=7

# --- Pluggy sandbox (used by connect-bank journey) --------------------------
# Public Pluggy sandbox test values (docs.pluggy.ai/docs/testing-connectors).
# These are NOT secrets — they're documented defaults for the sandbox environment.
#
# Basic aggregation flow (non-Open-Finance connectors):
#   username: user-ok  |  password: password-ok  |  MFA: 123456
#
# Open Finance flow (regulated BR banks, including sandbox Itaú):
#   CPF: 761.092.776-73  (basic success path)
#   Mock bank login after CPF prompt: richard.sim@mail.com / P@ssword01
#
# The journey spec uses the Open Finance CPF flow — sandbox Itaú is an OF connector.
PLUGGY_SANDBOX_CPF=761.092.776-73
PLUGGY_SANDBOX_PASSWORD=P@ssword01
# No pre-selected connector ID — the Pluggy Connect widget lets the user pick
# "Itaú (sandbox)" from its institution list. Leaving blank; the tester clicks
# the Itaú tile inside the widget.
PLUGGY_SANDBOX_ITAU_CONNECTOR_ID=
# Mock bank login email shown by the Pluggy widget after the CPF prompt.
PLUGGY_SANDBOX_MOCK_BANK_EMAIL=richard.sim@mail.com
