# Contably staging test credentials — one block per persona
# Copy to contably-staging.env and fill real values. NEVER commit the real file.
# Referenced by: /qa-conta-gate skill, via `credentials_ref` in apps/admin/src/__feature-map__.json

# --- Superadmin (Pierre) -----------------------------------------------------
# role=superuser, JWT has no fixed company_id, picks via UI switcher
STAGING_TEST_SUPERADMIN_EMAIL=
STAGING_TEST_SUPERADMIN_PASSWORD=
# Optional — default company to switch to when a journey needs one
STAGING_TEST_SUPERADMIN_DEFAULT_COMPANY_ID=

# --- Manager -----------------------------------------------------------------
# role=manager, full access within STAGING_TEST_MANAGER_COMPANY_ID
STAGING_TEST_MANAGER_EMAIL=
STAGING_TEST_MANAGER_PASSWORD=
STAGING_TEST_MANAGER_COMPANY_ID=

# --- Analyst -----------------------------------------------------------------
# role=analyst, read-only for bank-connections
STAGING_TEST_ANALYST_EMAIL=
STAGING_TEST_ANALYST_PASSWORD=
STAGING_TEST_ANALYST_COMPANY_ID=

# --- Client portal user ------------------------------------------------------
# role=client, must NOT reach admin routes
STAGING_TEST_CLIENT_EMAIL=
STAGING_TEST_CLIENT_PASSWORD=
STAGING_TEST_CLIENT_COMPANY_ID=

# --- Pluggy sandbox (used by connect-bank journey) --------------------------
# From https://dash.pluggy.ai → Sandbox → sandbox CPF & password
PLUGGY_SANDBOX_CPF=
PLUGGY_SANDBOX_PASSWORD=
# Connector ID for sandbox Itau (verify in Pluggy dashboard; common value is 1)
PLUGGY_SANDBOX_ITAU_CONNECTOR_ID=
