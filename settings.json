{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "GIT_TERMINAL_PROMPT=0 git -C \"$HOME/.claude-setup\" pull --ff-only --quiet 2>/dev/null || true; echo '=== CORE MEMORY ===' && cat \"$HOME/.claude-setup/memory/core-memory.json\" 2>/dev/null || echo 'No core memory found'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -rf /tmp/claude-agent-* 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude-setup/hooks/format-file.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude-setup/hooks/format-file.sh\""
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude-setup/hooks/format-file.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"additionalContext\": \"Working directory: '$(pwd)'. Git branch: '$(git branch --show-current 2>/dev/null || echo none)'. Project: '$(basename $(git rev-parse --show-toplevel 2>/dev/null) 2>/dev/null || basename $(pwd))'\"}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude-setup/hooks/session-end.sh\""
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[$(date)] Teammate idle - checking for pending work' >> ~/.claude/logs/teammates.log"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[$(date)] Task completed: ${TASK_ID}' >> ~/.claude/logs/tasks.log"
          },
          {
            "type": "prompt",
            "prompt": "Task completed. Use TaskList to check for unblocked tasks, then automatically assign the next available task to idle teammates."
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && echo '[$(date)] Config changed: ${CONFIG_FILE}' >> ~/.claude/logs/config-changes.log"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude-setup/hooks/worktree-create.sh\""
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude-setup/hooks/worktree-remove.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/psm2/.claude-setup/hooks/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Analyzing deal",
      "Extracting financials",
      "Scoring deal",
      "Reviewing codebase",
      "Running E2E tests",
      "Reviewing code",
      "Orchestrating project"
    ]
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "Use /mna triage to score M&A deals 0-10",
      "Use /ship for end-to-end feature delivery",
      "Use /optimize-setup to sync with Claude updates",
      "Use /research to analyze any URL or image",
      "Use /qa-cycle for full QA pass with Playwright"
    ]
  },
  "autoUpdaterStatus": "enabled",
  "alwaysThinkingEnabled": false,
  "plansDirectory": "~/.claude/plans",
  "skipDangerousModePermissionPrompt": true,
  "mcpSearchAutoThreshold": 15,
  "default_arguments": ["--dangerously-skip-permissions"],
  "mcp": {
    "mcpServers": {
      "sequential-thinking": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
        "description": "Sequential thinking and problem solving"
      },
      "memory": {
        "command": "node",
        "args": ["$HOME/.claude-setup/mcp-servers/memory-turso/dist/index.js"],
        "env": {
          "TURSO_DATABASE_URL": "libsql://claude-memory-escotilha.aws-us-east-1.turso.io",
          "TURSO_AUTH_TOKEN": "eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJpYXQiOjE3Njk2MDg3ODIsImlkIjoiZDUyM2I3OWEtZjA1My00M2U4LThhOGQtNjYwZTc1MmE0ZTY5IiwicmlkIjoiYTI3NDM2NWEtOWY3ZS00MTVlLTgxNTYtYzQxYzk2MWY4YTM0In0._TaT30NMCijZJhWyPmx_EGSzntWpyawyLoGh_JgASaHbrPkPNabsLsCfrArwLCCK1VBK9jE3NhSr9WLe_38gDg",
          "TURSO_LOCAL_REPLICA_PATH": "$HOME/.claude-setup/memory/turso-replica.db"
        },
        "description": "Knowledge graph for persistent memory (Turso-backed)"
      },
      "playwright": {
        "command": "npx",
        "args": ["-y", "@anthropic/mcp-playwright"],
        "description": "Browser automation with Playwright"
      },
      "github": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
        },
        "description": "GitHub API integration"
      },
      "brave-search": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-brave-search"],
        "env": {
          "BRAVE_API_KEY": "${BRAVE_API_KEY}"
        },
        "description": "Web search via Brave"
      },
      "postgres": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-postgres",
          "postgresql://postgres:postgres@127.0.0.1:5433/claudia"
        ],
        "description": "Claudia PostgreSQL on Contabo (via SSH tunnel :5433) - contacts, memory, workflows"
      },
      "resend": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-resend"],
        "env": {
          "RESEND_API_KEY": "${RESEND_API_KEY}"
        },
        "description": "Email sending via Resend"
      },
      "slack": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-slack"],
        "env": {
          "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
          "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
        },
        "description": "Slack integration"
      },
      "notion": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-notion"],
        "env": {
          "NOTION_API_KEY": "${NOTION_API_KEY}"
        },
        "description": "Notion integration"
      },
      "digitalocean": {
        "command": "npx",
        "args": [
          "-y",
          "@digitalocean/mcp",
          "--services",
          "apps,databases,spaces"
        ],
        "env": {
          "DIGITALOCEAN_TOKEN": "${DIGITALOCEAN_TOKEN}"
        },
        "description": "DigitalOcean App Platform, Databases, and Spaces management"
      },
      "chrome-devtools": {
        "command": "npx",
        "args": ["-y", "chrome-devtools-mcp@latest"],
        "description": "Chrome DevTools for browser automation and testing"
      },
      "google-workspace": {
        "command": "npx",
        "args": ["-y", "@presto-ai/google-workspace-mcp"],
        "description": "Gmail, Calendar, Drive, Docs, Sheets - OAuth authenticated"
      },
      "firecrawl": {
        "command": "npx",
        "args": ["-y", "firecrawl-mcp"],
        "env": {
          "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
        },
        "description": "Web scraping, crawling, search, and autonomous data extraction via Firecrawl"
      },
      "ScraplingServer": {
        "command": "/Users/psm2/.local/bin/scrapling",
        "args": ["mcp"],
        "description": "Stealth web scraping with anti-bot bypass, TLS fingerprint impersonation, and adaptive element tracking"
      }
    }
  }
}
