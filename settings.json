{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_BASH_NO_LOGIN": "1",
    "RESEND_API_KEY": "re_SBHeSKNj_AM1wzDrF5eJZ2LKmuyDyNvE2",
    "BRAVE_API_KEY": "BSAYdiKG6QoqYPSm9rCGdPlwM_fnzNu",
    "EXA_API_KEY": "81538a60-ff60-46e3-9fd4-78e954bc85d0"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "GIT_TERMINAL_PROMPT=0 git -C \u0022$HOME/.claude-setup\u0022 pull --ff-only --quiet 2\u003E/dev/null || true; echo \u0027=== CORE MEMORY ===\u0027 \u0026\u0026 cat \u0022$HOME/.claude-setup/memory/core-memory.json\u0022 2\u003E/dev/null || echo \u0027No core memory found\u0027"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Stop failure: exit_reason=${EXIT_REASON:-unknown} error=${ERROR_MESSAGE:-none}\u0022 \u003E\u003E ~/.claude/logs/stop-failures.log"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Subagent started: ${SUBAGENT_ID:-unknown}\u0022 \u003E\u003E ~/.claude/logs/subagents.log"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Subagent stopped: ${SUBAGENT_ID:-unknown}\u0022 \u003E\u003E ~/.claude/logs/subagents.log; rm -rf /tmp/claude-agent-* 2\u003E/dev/null || true"
          },
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/worktree-cleanup.sh\u0022"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/format-file.sh\u0022"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/format-file.sh\u0022"
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/format-file.sh\u0022"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/skill-execution-log.sh\u0022",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/memory-whisper.sh\u0022",
            "timeout": 4000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \u0027{\u0022additionalContext\u0022: \u0022Working directory: \u0027$(pwd)\u0027. Git branch: \u0027$(git branch --show-current 2\u003E/dev/null || echo none)\u0027. Project: \u0027$(basename $(git rev-parse --show-toplevel 2\u003E/dev/null) 2\u003E/dev/null || basename $(pwd))\u0027\u0022}\u0027"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/session-end.sh\u0022"
          },
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/worktree-cleanup.sh\u0022"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Teammate idle - checking for pending work\u0022 \u003E\u003E ~/.claude/logs/teammates.log"
          },
          {
            "type": "prompt",
            "prompt": "A teammate has gone idle. Check TaskList for unassigned tasks and assign work if available. If no tasks remain, shut down this teammate to save tokens."
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] First-run setup completed\u0022 \u003E\u003E ~/.claude/logs/setup.log"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Task completed: ${TASK_ID}\u0022 \u003E\u003E ~/.claude/logs/tasks.log"
          },
          {
            "type": "prompt",
            "prompt": "Task completed. Use TaskList to check for unblocked tasks, then automatically assign the next available task to idle teammates."
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Config changed: ${CONFIG_FILE}\u0022 \u003E\u003E ~/.claude/logs/config-changes.log"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/worktree-create.sh\u0022"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\u0022$HOME/.claude-setup/hooks/worktree-remove.sh\u0022"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Instructions loaded: ${INSTRUCTIONS_FILE}\u0022 \u003E\u003E ~/.claude/logs/instructions.log"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Compaction completed in $(pwd)\u0022 \u003E\u003E ~/.claude/logs/compaction.log"
          },
          {
            "type": "command",
            "command": "found=$(ls .deep-plan-state.json qa-state.json .claude/ship/*/state.json 2\u003E/dev/null); if [ -n \u0022$found\u0022 ]; then echo \u0022Active state files found: $found\u0022; else echo \u0022NO_STATE_FILES\u0022; fi"
          },
          {
            "type": "prompt",
            "prompt": "Context compaction just completed. If the hook output lists active state files, read them and summarize your current task phase and progress so you can continue without losing context. If it says NO_STATE_FILES, continue normally."
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] MCP elicitation requested: ${ELICITATION_SERVER:-unknown} request_id=${ELICITATION_ID:-unknown}\u0022 \u003E\u003E ~/.claude/logs/elicitations.log"
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] MCP elicitation result: ${ELICITATION_SERVER:-unknown} request_id=${ELICITATION_ID:-unknown} accepted=${ELICITATION_ACCEPTED:-unknown}\u0022 \u003E\u003E ~/.claude/logs/elicitations.log"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs \u0026\u0026 echo \u0022[$(date)] Task created: ${TASK_ID:-unknown} title=${TASK_TITLE:-unknown}\u0022 \u003E\u003E ~/.claude/logs/tasks.log"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "GIT_TERMINAL_PROMPT=0 git branch --show-current 2\u003E/dev/null | xargs -I{} echo \u0027{\u0022additionalContext\u0022: \u0022Now in directory: \u0027\u0022$(pwd)\u0022\u0027. Git branch: {}\u0022}\u0027 2\u003E/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude-setup/hooks/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "claude-subconscious@letta-ai-claude-subconscious": false,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Analyzing deal",
      "Extracting financials",
      "Scoring deal",
      "Reviewing codebase",
      "Running E2E tests",
      "Reviewing code",
      "Orchestrating project"
    ]
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "Use /mna triage to score M\u0026A deals 0-10",
      "Use /ship for end-to-end feature delivery",
      "Use /optimize-setup to sync with Claude updates",
      "Use /research to analyze any URL or image",
      "Use /qa-cycle for full QA pass with Playwright"
    ]
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "high",
  "plansDirectory": "~/.claude/plans",
  "autoMemoryDirectory": "~/.claude-setup/memory/auto",
  "skipDangerousModePermissionPrompt": true,
  "autoUpdaterStatus": "enabled",
  "remoteControlForAllSessions": true,
  "mcpSearchAutoThreshold": 15,
  "default_arguments": [
    "--dangerously-skip-permissions"
  ],
  "mcp": {
    "mcpServers": {
      "sequential-thinking": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-sequential-thinking"
        ],
        "description": "Sequential thinking and problem solving"
      },
      "memory": {
        "command": "node",
        "args": [
          "$HOME/.claude-setup/mcp-servers/memory-turso/dist/index.js"
        ],
        "env": {
          "TURSO_DATABASE_URL": "libsql://claude-memory-escotilha.aws-us-east-1.turso.io",
          "TURSO_AUTH_TOKEN": "eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJpYXQiOjE3Njk2MDg3ODIsImlkIjoiZDUyM2I3OWEtZjA1My00M2U4LThhOGQtNjYwZTc1MmE0ZTY5IiwicmlkIjoiYTI3NDM2NWEtOWY3ZS00MTVlLTgxNTYtYzQxYzk2MWY4YTM0In0._TaT30NMCijZJhWyPmx_EGSzntWpyawyLoGh_JgASaHbrPkPNabsLsCfrArwLCCK1VBK9jE3NhSr9WLe_38gDg",
          "TURSO_LOCAL_REPLICA_PATH": "$HOME/.claude-setup/memory/turso-replica.db"
        },
        "description": "Knowledge graph for persistent memory (Turso-backed)"
      },
      "playwright": {
        "command": "npx",
        "args": [
          "-y",
          "@anthropic/mcp-playwright"
        ],
        "description": "Browser automation with Playwright"
      },
      "github": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-github"
        ],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
        },
        "description": "GitHub API integration"
      },
      "brave-search": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-brave-search"
        ],
        "env": {
          "BRAVE_API_KEY": "${BRAVE_API_KEY}"
        },
        "description": "Web search via Brave LLM Context API \u2014 use count param to control token budget"
      },
      "exa": {
        "command": "npx",
        "args": [
          "-y",
          "exa-mcp-server"
        ],
        "env": {
          "EXA_API_KEY": "${EXA_API_KEY}"
        },
        "description": "Neural search with highlights mode \u2014 returns only query-relevant passages for minimal token usage"
      },
      "postgres": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-postgres",
          "postgresql://postgres:postgres@127.0.0.1:5433/claudia"
        ],
        "description": "Claudia PostgreSQL on Contabo (via SSH tunnel :5433) - contacts, memory, workflows"
      },
      "resend": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-resend"
        ],
        "env": {
          "RESEND_API_KEY": "${RESEND_API_KEY}"
        },
        "description": "Email sending via Resend"
      },
      "slack": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-slack"
        ],
        "env": {
          "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
          "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
        },
        "description": "Slack integration"
      },
      "notion": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-notion"
        ],
        "env": {
          "NOTION_API_KEY": "${NOTION_API_KEY}"
        },
        "description": "Notion integration"
      },
      "digitalocean": {
        "command": "npx",
        "args": [
          "-y",
          "@digitalocean/mcp",
          "--services",
          "apps,databases,spaces"
        ],
        "env": {
          "DIGITALOCEAN_TOKEN": "${DIGITALOCEAN_TOKEN}"
        },
        "description": "DigitalOcean App Platform, Databases, and Spaces management"
      },
      "chrome-devtools": {
        "command": "npx",
        "args": [
          "-y",
          "chrome-devtools-mcp@latest"
        ],
        "description": "Chrome DevTools for browser automation and testing"
      },
      "firecrawl": {
        "command": "npx",
        "args": [
          "-y",
          "firecrawl-mcp"
        ],
        "env": {
          "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
        },
        "description": "Web scraping, crawling, search, and autonomous data extraction via Firecrawl"
      },
      "ScraplingServer": {
        "command": "$HOME/.local/bin/scrapling",
        "args": [
          "mcp"
        ],
        "description": "Stealth web scraping with anti-bot bypass, TLS fingerprint impersonation, and adaptive element tracking"
      },
      "context-mode": {
        "command": "npx",
        "args": [
          "-y",
          "context-mode"
        ],
        "description": "Context window compression: batches tool calls, indexes large outputs for query-based retrieval"
      },
      "qmd": {
        "command": "qmd",
        "args": [
          "mcp"
        ],
        "description": "On-device hybrid search (BM25 \u002B vector \u002B LLM rerank) over indexed markdown collections: skills, agents, rules, memory"
      }
    }
  },
  "mcpServers": {
    "officecli": {
      "command": "/Users/ps/.local/bin/officecli",
      "args": [
        "mcp"
      ]
    }
  }
}
