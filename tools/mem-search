#!/usr/bin/env bash
# mem-search — FTS5 search over Claude Code auto-memory
# Uses macOS built-in sqlite3 with FTS5 for full-text search.
# Indexes .md files from ~/.claude-setup/memory/auto/ (excluding MEMORY.md).
set -euo pipefail

MEMORY_DIR="$HOME/.claude-setup/memory/auto"
DB_PATH="$HOME/.claude-setup/tools/mem-search.db"
QUERY="${1:-}"

# --- Functions ---

init_db() {
  sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS memories (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  file_path TEXT NOT NULL UNIQUE,
  name TEXT,
  description TEXT,
  type TEXT,
  content TEXT NOT NULL,
  modified_at TEXT,
  created_at TEXT DEFAULT (datetime('now'))
);
CREATE VIRTUAL TABLE IF NOT EXISTS memories_fts USING fts5(
  name, description, content, type,
  content=memories,
  content_rowid=id,
  tokenize='porter unicode61'
);
CREATE TRIGGER IF NOT EXISTS memories_ai AFTER INSERT ON memories BEGIN
  INSERT INTO memories_fts(rowid, name, description, content, type)
  VALUES (new.id, new.name, new.description, new.content, new.type);
END;
CREATE TRIGGER IF NOT EXISTS memories_ad AFTER DELETE ON memories BEGIN
  INSERT INTO memories_fts(memories_fts, rowid, name, description, content, type)
  VALUES ('delete', old.id, old.name, old.description, old.content, old.type);
END;
CREATE TRIGGER IF NOT EXISTS memories_au AFTER UPDATE ON memories BEGIN
  INSERT INTO memories_fts(memories_fts, rowid, name, description, content, type)
  VALUES ('delete', old.id, old.name, old.description, old.content, old.type);
  INSERT INTO memories_fts(rowid, name, description, content, type)
  VALUES (new.id, new.name, new.description, new.content, new.type);
END;
SQL
}

reindex() {
  echo "[mem-search] Reindexing from $MEMORY_DIR ..."

  # Drop and recreate for clean reindex
  sqlite3 "$DB_PATH" "DELETE FROM memories;"
  sqlite3 "$DB_PATH" "INSERT INTO memories_fts(memories_fts) VALUES('rebuild');"

  local count=0
  local tmpdir
  tmpdir=$(mktemp -d)
  trap "rm -rf '$tmpdir'" RETURN

  for f in "$MEMORY_DIR"/*.md; do
    [[ "$(basename "$f")" == "MEMORY.md" ]] && continue
    [[ ! -f "$f" ]] && continue

    local name="" description="" type="" content=""
    local in_frontmatter=0 frontmatter_done=0

    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ $frontmatter_done -eq 0 ]]; then
        if [[ "$line" == "---" && $in_frontmatter -eq 0 ]]; then
          in_frontmatter=1
          continue
        elif [[ "$line" == "---" && $in_frontmatter -eq 1 ]]; then
          frontmatter_done=1
          continue
        elif [[ $in_frontmatter -eq 1 ]]; then
          case "$line" in
            name:*) name="${line#name:}" ; name="${name# }" ;;
            description:*) description="${line#description:}" ; description="${description# }" ;;
            type:*) type="${line#type:}" ; type="${type# }" ;;
          esac
          continue
        fi
      fi
      content+="$line"$'\n'
    done < "$f"

    # Strip surrounding quotes from parsed values
    name="${name#\"}" ; name="${name%\"}"
    name="${name#\'}" ; name="${name%\'}"
    description="${description#\"}" ; description="${description%\"}"
    description="${description#\'}" ; description="${description%\'}"
    type="${type#\"}" ; type="${type%\"}"
    type="${type#\'}" ; type="${type%\'}"

    local mod_date
    mod_date=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d. -f1)

    # Write each field to a temp file, then build SQL with proper escaping
    # using sed to double single quotes (the only escaping sqlite3 needs)
    local sql_file="$tmpdir/insert.sql"
    {
      printf "INSERT INTO memories (file_path, name, description, type, content, modified_at) VALUES ("
      printf "'%s', " "$(printf '%s' "$f" | sed "s/'/''/g")"
      printf "'%s', " "$(printf '%s' "$name" | sed "s/'/''/g")"
      printf "'%s', " "$(printf '%s' "$description" | sed "s/'/''/g")"
      printf "'%s', " "$(printf '%s' "$type" | sed "s/'/''/g")"
      printf "'%s', " "$(printf '%s' "$content" | sed "s/'/''/g")"
      printf "'%s'" "$(printf '%s' "$mod_date" | sed "s/'/''/g")"
      printf ");\n"
    } > "$sql_file"

    sqlite3 "$DB_PATH" < "$sql_file"
    count=$((count + 1))
  done

  echo "[mem-search] Indexed $count memory files."
}

search() {
  local query="$1"

  # Check if DB exists and has data
  if [[ ! -f "$DB_PATH" ]]; then
    init_db
    reindex
  fi

  local count
  count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM memories;" 2>/dev/null || echo "0")
  if [[ "$count" == "0" ]]; then
    reindex
  fi

  # Escape single quotes in query for SQL
  local safe_query="${query//\'/\'\'}"

  # FTS5 search with BM25 ranking
  # Column weights: name=5, description=3, content=1, type=2
  # Type boost: feedback 3x, user 2x, reference 1.5x
  # Recency boost: modified in last 7 days gets 1.5x
  sqlite3 -header -column "$DB_PATH" <<EOSQL
SELECT
  m.name,
  m.type,
  m.description,
  ROUND(
    bm25(memories_fts, 5.0, 3.0, 1.0, 2.0) * -1.0
    * CASE m.type
        WHEN 'feedback' THEN 3.0
        WHEN 'user' THEN 2.0
        WHEN 'reference' THEN 1.5
        ELSE 1.0
      END
    * CASE
        WHEN julianday('now') - julianday(m.modified_at) <= 7 THEN 1.5
        ELSE 1.0
      END
  , 2) as score,
  SUBSTR(snippet(memories_fts, 2, '>>>', '<<<', '...', 40), 1, 200) as match_snippet
FROM memories_fts
JOIN memories m ON m.id = memories_fts.rowid
WHERE memories_fts MATCH '$safe_query'
ORDER BY score DESC
LIMIT 10;
EOSQL
}

read_match() {
  local query="$1"

  if [[ ! -f "$DB_PATH" ]]; then
    echo "No database. Run: mem-search --reindex"
    return 1
  fi

  local safe_query="${query//\'/\'\'}"

  # Get the top match file path
  local file_path
  file_path=$(sqlite3 "$DB_PATH" <<EOSQL
SELECT m.file_path
FROM memories_fts
JOIN memories m ON m.id = memories_fts.rowid
WHERE memories_fts MATCH '$safe_query'
ORDER BY bm25(memories_fts, 5.0, 3.0, 1.0, 2.0) ASC
LIMIT 1;
EOSQL
  )

  if [[ -z "$file_path" ]]; then
    echo "No match found for: $query"
    return 1
  fi

  echo "--- $file_path ---"
  cat "$file_path"
}

stats() {
  if [[ ! -f "$DB_PATH" ]]; then
    echo "No database. Run: mem-search --reindex"
    return
  fi
  echo "=== Memory Search Stats ==="
  echo ""
  sqlite3 -header -column "$DB_PATH" "SELECT type, COUNT(*) as count FROM memories GROUP BY type ORDER BY count DESC;"
  echo ""
  sqlite3 "$DB_PATH" "SELECT COUNT(*) || ' total memories indexed' FROM memories;"
  echo ""
  echo "Database: $(du -h "$DB_PATH" | cut -f1)"
  echo "Location: $DB_PATH"
  echo "Source:   $MEMORY_DIR"
}

# --- Main ---

case "${QUERY}" in
  --reindex)
    init_db
    reindex
    ;;
  --stats)
    stats
    ;;
  --read)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: mem-search --read <query>"
      exit 1
    fi
    read_match "$2"
    ;;
  --help|-h|"")
    echo "mem-search — FTS5 search over Claude Code auto-memory"
    echo ""
    echo "Usage:"
    echo "  mem-search <query>          Search memories (FTS5 syntax)"
    echo "  mem-search --read <query>   Show full content of top match"
    echo "  mem-search --reindex        Rebuild index from .md files"
    echo "  mem-search --stats          Show memory statistics"
    echo ""
    echo "Query examples:"
    echo "  mem-search security          Simple keyword"
    echo "  mem-search 'agent OR sandbox' Boolean OR"
    echo "  mem-search 'browse AND cli'   Boolean AND"
    echo "  mem-search 'name:resend'      Search specific column"
    echo "  mem-search 'type:reference'   Filter by type"
    ;;
  *)
    search "$QUERY"
    ;;
esac
