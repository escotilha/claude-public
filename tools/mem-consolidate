#!/usr/bin/env bash
# mem-consolidate — Automated memory maintenance
# Run nightly via launchd (com.claude-setup.mem-consolidate)
# Prunes stale memories, deduplicates, rebuilds MEMORY.md index
set -euo pipefail

MEMORY_DIR="$HOME/.claude-setup/memory/auto"
MEMORY_INDEX="$MEMORY_DIR/MEMORY.md"
LOG_FILE="$HOME/.claude-setup/tools/mem-consolidate.log"
TODAY=$(date +%Y-%m-%d)
DECAY_DAYS=90
MIN_LINES=3  # Minimum content lines to keep a memory

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"; }

log "=== Consolidation started ==="

# Helper: enumerate all memory files (root + tier subdirs), excluding indices
list_memory_files() {
  find "$MEMORY_DIR" -maxdepth 2 -type f -name "*.md" \
    ! -name "MEMORY.md" ! -name "_tier.md" ! -name "_index.md" 2>/dev/null
}

# --- Step 1: Prune stale memories ---
PRUNED=0
while IFS= read -r f; do
  [[ ! -f "$f" ]] && continue

  # Get modification date (macOS stat format)
  mod_date=$(stat -f "%Sm" -t "%Y-%m-%d" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d' ' -f1)

  # Calculate age in days
  mod_epoch=$(date -j -f "%Y-%m-%d" "$mod_date" "+%s" 2>/dev/null || date -d "$mod_date" "+%s" 2>/dev/null)
  now_epoch=$(date "+%s")
  age_days=$(( (now_epoch - mod_epoch) / 86400 ))

  # Check content length (proxy for value — very short memories are likely low-value)
  content_lines=$(grep -c -v -E "^---$|^$|^name:|^description:|^type:" "$f" 2>/dev/null || echo "0")

  # Skip pruning files in personal/ tier (never auto-decay per memory-strategy.md)
  if [[ "$f" == *"/personal/"* ]]; then
    continue
  fi

  if [[ $age_days -gt $DECAY_DAYS && $content_lines -lt $MIN_LINES ]]; then
    log "PRUNE: $(basename "$f") — $age_days days old, $content_lines content lines"
    rm "$f"
    PRUNED=$((PRUNED + 1))
  fi
done < <(list_memory_files)
log "Pruned $PRUNED stale memories"

# --- Step 2: Detect near-duplicates by description ---
# Uses a temp file for bash 3.2 compatibility (macOS ships bash 3, no associative arrays)
DEDUP_INDEX=$(mktemp /tmp/mem-consolidate-dedup.XXXXXX)
trap "rm -f '$DEDUP_INDEX'" EXIT
DUPES=0
while IFS= read -r f; do
  [[ ! -f "$f" ]] && continue

  desc=$(grep "^description:" "$f" 2>/dev/null | head -1 | sed 's/^description: *//' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 ]//g' | xargs || true)
  [[ -z "$desc" ]] && continue

  # Check if we've already seen this description
  existing=$(grep -F "	$desc" "$DEDUP_INDEX" 2>/dev/null | head -1 | cut -f1 || true)

  if [[ -n "$existing" && -f "$existing" ]]; then
    # Keep the newer file (higher mtime), remove the older
    existing_mod=$(stat -f "%m" "$existing" 2>/dev/null || stat -c "%Y" "$existing" 2>/dev/null)
    current_mod=$(stat -f "%m" "$f" 2>/dev/null || stat -c "%Y" "$f" 2>/dev/null)

    if [[ $current_mod -gt $existing_mod ]]; then
      log "DEDUP: Removing older $(basename "$existing"), keeping $(basename "$f")"
      rm "$existing"
      # Replace the entry in the index
      grep -v -F "	$desc" "$DEDUP_INDEX" > "${DEDUP_INDEX}.tmp" 2>/dev/null || true
      mv "${DEDUP_INDEX}.tmp" "$DEDUP_INDEX"
      printf '%s\t%s\n' "$f" "$desc" >> "$DEDUP_INDEX"
    else
      log "DEDUP: Removing older $(basename "$f"), keeping $(basename "$existing")"
      rm "$f"
    fi
    DUPES=$((DUPES + 1))
  else
    printf '%s\t%s\n' "$f" "$desc" >> "$DEDUP_INDEX"
  fi
done < <(list_memory_files)
log "Removed $DUPES duplicates"

# --- Step 3: Rebuild MEMORY.md index (tier-aware, recursive) ---
# Tier order: tiered structure first (active), legacy flat dirs second
TIER_LIST=(
  "personal:Personal — preferences, credentials, host"
  "semantic:Semantic — patterns, mistakes, tech-insights"
  "working:Working — live state, handoff buffers"
  "episodic:Episodic — project timeline"
  "entities:Entities (legacy) — agents, deals, registries"
  "concepts:Concepts (legacy) — patterns, tech, mistakes"
  "feedback:Feedback (legacy)"
  "projects:Projects (legacy)"
  "reference:Reference (legacy)"
)

extract_desc() {
  local f="$1"
  local d
  d=$(awk '/^description:/{sub(/^description: */,""); gsub(/^"|"$/,""); print; exit}' "$f" 2>/dev/null)
  if [[ -z "$d" ]]; then
    d=$(grep -m1 -E '^[A-Za-z]' "$f" 2>/dev/null | sed 's/^# *//' | head -c 140)
  fi
  echo "${d:0:140}"
}

{
  echo "# Memory Index"
  echo ""
  TOTAL_COUNT=$(find "$MEMORY_DIR" -maxdepth 2 -name "*.md" \
    ! -name "MEMORY.md" ! -name "_tier.md" ! -name "_index.md" 2>/dev/null | wc -l | xargs)
  echo "*Rebuilt $TODAY. $TOTAL_COUNT entries indexed.*"
  echo ""

  # Root-level files (auto/*.md, not in any tier)
  root_files=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && root_files+=("$f")
  done < <(find "$MEMORY_DIR" -maxdepth 1 -name "*.md" \
    ! -name "MEMORY.md" 2>/dev/null | sort)

  if [[ ${#root_files[@]} -gt 0 ]]; then
    echo "## Root"
    echo ""
    for f in "${root_files[@]}"; do
      fname=$(basename "$f")
      desc=$(extract_desc "$f")
      echo "- [$fname]($fname) — $desc"
    done
    echo ""
  fi

  # Tier dirs
  for tier_entry in "${TIER_LIST[@]}"; do
    tier="${tier_entry%%:*}"
    label="${tier_entry#*:}"
    tier_dir="$MEMORY_DIR/$tier"
    [[ ! -d "$tier_dir" ]] && continue

    tier_files=()
    while IFS= read -r f; do
      [[ -n "$f" ]] && tier_files+=("$f")
    done < <(find "$tier_dir" -maxdepth 1 -name "*.md" \
      ! -name "_tier.md" ! -name "_index.md" 2>/dev/null | sort)

    [[ ${#tier_files[@]} -eq 0 ]] && continue

    echo "## $label"
    echo ""
    for f in "${tier_files[@]}"; do
      fname=$(basename "$f")
      rel="$tier/$fname"
      desc=$(extract_desc "$f")
      echo "- [$rel]($rel) — $desc"
    done
    echo ""
  done

  echo "# currentDate"
  echo "Today's date is $TODAY."
} > "$MEMORY_INDEX"

TOTAL=$(find "$MEMORY_DIR" -maxdepth 2 -name "*.md" \
  ! -name "MEMORY.md" ! -name "_tier.md" ! -name "_index.md" 2>/dev/null | wc -l | xargs)
log "Rebuilt MEMORY.md index with $TOTAL entries"

# --- Step 4: Reindex search (FTS5) if mem-search exists ---
if [[ -x "$HOME/.claude-setup/tools/mem-search" ]]; then
  "$HOME/.claude-setup/tools/mem-search" --reindex --fts-only >> "$LOG_FILE" 2>&1 || true
  log "FTS5 index updated"
fi

# --- Step 5: Incremental vector re-embed (hybrid retrieval layer) ---
# Skips if MEM_HYBRID=0 or mem-embed not installed. Non-fatal if it fails —
# FTS5 index is still current. Uses perl alarm as a portable timeout wrapper
# (macOS base has no `timeout` command; gtimeout via coreutils would be an alternative).
run_with_timeout() {
  local secs="$1"; shift
  perl -e 'alarm shift; exec @ARGV' "$secs" "$@"
}

if [[ "${MEM_HYBRID:-1}" == "1" && -x "$HOME/.claude-setup/tools/mem-embed" ]]; then
  embed_start=$(date +%s)
  if run_with_timeout 600 "$HOME/.claude-setup/tools/mem-embed" incremental >> "$LOG_FILE" 2>&1; then
    embed_dur=$(( $(date +%s) - embed_start ))
    log "Vector incremental re-embed completed in ${embed_dur}s"
  else
    log "Vector incremental re-embed FAILED (non-fatal; FTS5 index still current)"
  fi
else
  log "Vector embed disabled (MEM_HYBRID=0 or mem-embed binary missing)"
fi

# --- Step 6: Regenerate llms.txt + llms-full.txt (LLM-discoverable setup index) ---
# These reflect the current state of skills/ and rules/. Regenerate whenever
# consolidation runs so the files never go stale by more than a day.
if [[ -x "$HOME/.claude-setup/tools/build-llms.sh" ]]; then
  if "$HOME/.claude-setup/tools/build-llms.sh" >> "$LOG_FILE" 2>&1; then
    log "Regenerated llms.txt + llms-full.txt"
  else
    log "build-llms FAILED (non-fatal)"
  fi
fi

log "=== Consolidation complete: pruned=$PRUNED, deduped=$DUPES, total=$TOTAL ==="
