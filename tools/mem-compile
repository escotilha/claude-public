#!/usr/bin/env python3
"""mem-compile — compile auto/ vault into machine-readable agent digest.

Reads every .md file under ~/.claude-setup/memory/auto/{entities,concepts,projects,feedback,reference}/
Extracts frontmatter (name, description, type) and the compiled truth (prose before --- Timeline).
Writes three artifacts under ~/.claude-setup/memory/auto/.cache/:
  - agent-digest.json: compact array of {path, name, type, description, truth, mtime}
  - index.json: fast lookup map {basename: path}
  - stats.json: counts, stale pages, link-density stats

Also emits reports/ dashboards (stale-pages.md, orphans.md) inside auto/.
"""
from __future__ import annotations

import json
import os
import re
import sys
import time
from pathlib import Path
from typing import Any

BASE = Path.home() / ".claude-setup" / "memory" / "auto"
CACHE = BASE / ".cache"
REPORTS = BASE / "reports"
# Legacy flat dirs + new tier taxonomy (working/episodic/semantic/personal).
# Both are scanned so migration can be touch-and-promote without losing coverage.
CATS = [
    "entities", "concepts", "projects", "feedback", "reference",
    "working", "episodic", "semantic", "personal",
]
TIER_MARKERS = {"_tier.md", "_index.md"}  # per-tier/legacy rule + index docs, not memories

FRONTMATTER_RE = re.compile(r"^---\n(.*?)\n---\n(.*)$", re.DOTALL)
TIMELINE_RE = re.compile(r"\n\n---\n\n## Timeline", re.DOTALL)
RELATED_RE = re.compile(r"Related:\s*\[", re.IGNORECASE)
LINK_RE = re.compile(r"\]\(([a-z][^)]+\.md)\)")


def parse_frontmatter(text: str) -> tuple[dict[str, str], str]:
    m = FRONTMATTER_RE.match(text)
    if not m:
        return {}, text
    fm_raw, body = m.group(1), m.group(2)
    fm: dict[str, str] = {}
    for line in fm_raw.splitlines():
        if ":" not in line:
            continue
        k, _, v = line.partition(":")
        v = v.strip().strip('"').strip("'")
        fm[k.strip()] = v
    return fm, body


def extract_truth(body: str) -> str:
    """Return content before the Timeline section (compiled truth)."""
    parts = TIMELINE_RE.split(body, maxsplit=1)
    return parts[0].strip()


def collect() -> dict[str, Any]:
    entries: list[dict[str, Any]] = []
    index: dict[str, str] = {}
    stale_days = 90
    now = time.time()
    stale: list[dict[str, Any]] = []
    orphans: list[str] = []

    # First pass: gather all files + build inbound-link counter
    inbound: dict[str, int] = {}
    outbound_raw: dict[str, list[str]] = {}

    files: list[tuple[str, Path]] = []
    for cat in CATS:
        d = BASE / cat
        if not d.is_dir():
            continue
        for p in sorted(d.glob("*.md")):
            if p.name in TIER_MARKERS:
                continue
            files.append((cat, p))

    for cat, p in files:
        rel = f"{cat}/{p.name}"
        index[p.name] = rel
        text = p.read_text()
        for link in LINK_RE.findall(text):
            # link may already be prefixed; normalize to basename
            basename = link.split("/")[-1]
            outbound_raw.setdefault(rel, []).append(basename)
            inbound[basename] = inbound.get(basename, 0) + 1

    # Second pass: build entries
    for cat, p in files:
        rel = f"{cat}/{p.name}"
        text = p.read_text()
        fm, body = parse_frontmatter(text)
        truth = extract_truth(body)
        mtime = p.stat().st_mtime
        age_days = int((now - mtime) / 86400)
        has_related = bool(RELATED_RE.search(text))
        outbound = outbound_raw.get(rel, [])
        inbound_count = inbound.get(p.name, 0)

        entry = {
            "path": rel,
            "basename": p.name,
            "category": cat,
            "name": fm.get("name", p.stem),
            "type": fm.get("type", ""),
            "description": fm.get("description", ""),
            "truth_preview": truth[:400],
            "mtime": int(mtime),
            "age_days": age_days,
            "inbound_links": inbound_count,
            "outbound_links": len(outbound),
            "has_related_block": has_related,
        }
        entries.append(entry)

        if age_days > stale_days:
            stale.append({"path": rel, "age_days": age_days, "description": entry["description"]})
        if inbound_count == 0 and len(outbound) == 0:
            orphans.append(rel)

    by_cat: dict[str, int] = {}
    for e in entries:
        by_cat[e["category"]] = by_cat.get(e["category"], 0) + 1

    stats = {
        "total": len(entries),
        "by_category": by_cat,
        "stale_count": len(stale),
        "orphan_count": len(orphans),
        "with_related_block": sum(1 for e in entries if e["has_related_block"]),
        "avg_inbound": round(sum(e["inbound_links"] for e in entries) / max(len(entries), 1), 2),
        "compiled_at": int(now),
    }

    return {"entries": entries, "index": index, "stats": stats, "stale": stale, "orphans": orphans}


TIERS = ["working", "episodic", "semantic", "personal"]
LEGACY_CATS = ["entities", "concepts", "projects", "feedback", "reference"]

STOPWORDS = {
    "the", "a", "an", "and", "or", "but", "of", "for", "to", "in", "on", "at", "by",
    "with", "from", "as", "is", "are", "was", "were", "be", "been", "being",
    "this", "that", "these", "those", "it", "its", "into", "via", "over",
    "memory", "file", "page", "per", "use", "using", "used",
}

TYPE_PREFIXES = ("tech", "pattern", "mistake", "feedback", "reference", "preference", "project", "user", "entity")


def _normalize_desc(desc: str) -> set[str]:
    toks = re.findall(r"[a-zA-Z][a-zA-Z0-9\-]{2,}", desc.lower())
    return {t for t in toks if t not in STOPWORDS and len(t) > 2}


def _page_file(entry: dict[str, Any]) -> Path:
    return BASE / entry["path"]


def write_graph_report(data: dict[str, Any]) -> None:
    """Emit reports/GRAPH_REPORT.md — link-graph only (v1)."""
    entries = data["entries"]
    st = data["stats"]
    now = time.time()
    ts = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(now))

    lines: list[str] = [
        "# GRAPH_REPORT",
        "",
        f"**Compiled at:** {ts}",
        f"**Source:** mem-compile — link-graph only (v1)",
        f"**Corpus:** {st['total']} pages across {len(st['by_category'])} directories",
        "",
        "This is an auto-generated digest of the memory graph. Read this before",
        "`mem-search` when you need a bird's-eye view of what the vault contains,",
        "which pages are hubs, and where cross-links are missing.",
        "",
    ]

    # 1. Tier coverage table (tier × count × avg age)
    lines += ["## Tier coverage", "", "| Tier | Count | Avg age (d) | Stale (>90d) | Orphans |", "|---|---:|---:|---:|---:|"]
    buckets: dict[str, list[dict[str, Any]]] = {}
    for e in entries:
        buckets.setdefault(e["category"], []).append(e)
    # Tiers first, then legacy.
    for cat in TIERS + LEGACY_CATS:
        rows = buckets.get(cat, [])
        if not rows:
            if cat in TIERS:
                lines.append(f"| `{cat}/` | 0 | — | — | — |")
            continue
        count = len(rows)
        avg_age = sum(r["age_days"] for r in rows) / count
        stale_ct = sum(1 for r in rows if r["age_days"] > 90)
        orph_ct = sum(1 for r in rows if r["inbound_links"] == 0 and r["outbound_links"] == 0)
        lines.append(f"| `{cat}/` | {count} | {avg_age:.0f} | {stale_ct} | {orph_ct} |")
    lines += [""]

    # 2. Hub pages — top 10 by inbound links
    lines += ["## Hub pages (top 10 by inbound links)", ""]
    hubs = sorted(entries, key=lambda e: (-e["inbound_links"], e["age_days"]))[:10]
    for h in hubs:
        if h["inbound_links"] == 0:
            continue
        preview = (h["description"] or h["truth_preview"])[:120].replace("|", "\\|")
        lines.append(f"- **{h['inbound_links']} ←** [`{h['path']}`]({h['path']}) — {preview}")
    if not any(h["inbound_links"] > 0 for h in hubs):
        lines.append("_No pages have inbound links yet. Cross-link new memories when writing them._")
    lines += [""]

    # 3. Recent clusters (last 14 days) — group by shared description tokens.
    lines += ["## Recent clusters (last 14 days)", ""]
    recent = [e for e in entries if e["age_days"] <= 14]
    if not recent:
        lines.append("_No memories modified in the last 14 days._")
    else:
        # Simple clustering: union-find on Jaccard >= 0.3 between description token sets.
        tokens = {e["path"]: _normalize_desc(e["description"]) for e in recent}
        parent: dict[str, str] = {p: p for p in tokens}

        def find(x: str) -> str:
            while parent[x] != x:
                parent[x] = parent[parent[x]]
                x = parent[x]
            return x

        def union(a: str, b: str) -> None:
            ra, rb = find(a), find(b)
            if ra != rb:
                parent[ra] = rb

        paths = list(tokens.keys())
        for i, a in enumerate(paths):
            for b in paths[i + 1:]:
                if not tokens[a] or not tokens[b]:
                    continue
                inter = len(tokens[a] & tokens[b])
                if not inter:
                    continue
                union_size = len(tokens[a] | tokens[b])
                if union_size and inter / union_size >= 0.3:
                    union(a, b)

        clusters: dict[str, list[dict[str, Any]]] = {}
        by_path = {e["path"]: e for e in recent}
        for p in paths:
            clusters.setdefault(find(p), []).append(by_path[p])

        # Render clusters with >= 2 members first, then singletons.
        multi = [c for c in clusters.values() if len(c) >= 2]
        singles = [c[0] for c in clusters.values() if len(c) == 1]
        for i, cluster in enumerate(sorted(multi, key=lambda c: -len(c)), start=1):
            shared = set.intersection(*[_normalize_desc(x["description"]) for x in cluster]) if len(cluster) > 1 else set()
            tag = ", ".join(sorted(shared)[:4]) or "(no shared tokens)"
            lines.append(f"**Cluster {i}** — {tag}")
            for m in sorted(cluster, key=lambda x: x["age_days"]):
                lines.append(f"- [`{m['path']}`]({m['path']}) ({m['age_days']}d ago) — {m['description'][:100]}")
            lines.append("")
        if singles:
            lines.append("**Unclustered** (recent, no peers)")
            for s in sorted(singles, key=lambda x: x["age_days"]):
                lines.append(f"- [`{s['path']}`]({s['path']}) ({s['age_days']}d ago) — {s['description'][:100]}")
            lines.append("")

    # 4. Orphans (inlined)
    lines += ["## Orphans (no inbound + no outbound links)", ""]
    if data["orphans"]:
        for o in sorted(data["orphans"])[:30]:
            lines.append(f"- `{o}`")
        if len(data["orphans"]) > 30:
            lines.append(f"- … and {len(data['orphans']) - 30} more")
    else:
        lines.append("_None. The link graph is fully connected._")
    lines += [""]

    # 5. Stale (inlined — top 10)
    lines += ["## Stale pages (>90d, top 10 oldest)", ""]
    stale_sorted = sorted(data["stale"], key=lambda x: -x["age_days"])[:10]
    if stale_sorted:
        for s in stale_sorted:
            lines.append(f"- **{s['age_days']}d** `{s['path']}` — {s['description'][:100]}")
    else:
        lines.append("_None. All memories touched within 90 days._")
    lines += [""]

    # 6. Contradiction candidates — normalized description dedup (v1, no vectors)
    lines += ["## Contradiction candidates (near-duplicate descriptions)", ""]
    desc_groups: dict[str, list[dict[str, Any]]] = {}
    for e in entries:
        if not e["description"]:
            continue
        norm = re.sub(r"[^a-z0-9 ]+", " ", e["description"].lower())
        norm = re.sub(r"\s+", " ", norm).strip()
        norm = " ".join(norm.split()[:6])  # first 6 tokens → rough cluster key
        if not norm:
            continue
        desc_groups.setdefault(norm, []).append(e)
    dups = [(k, v) for k, v in desc_groups.items() if len(v) >= 2]
    if dups:
        for key, group in sorted(dups, key=lambda kv: -len(kv[1]))[:15]:
            lines.append(f"- `{key}` ({len(group)} pages):")
            for e in group:
                lines.append(f"    - [`{e['path']}`]({e['path']})")
    else:
        lines.append("_No near-duplicate descriptions detected._")
    lines += [""]

    # 7. Tier-gate suggestions — legacy files that look tier-ready
    lines += ["## Tier-gate suggestions", "", "_Legacy-dir files whose content looks tier-ready._", ""]
    suggestions: list[str] = []
    for e in entries:
        if e["category"] not in LEGACY_CATS:
            continue
        basename = e["basename"]
        # Heuristic: prefix-based matching on file name.
        target = None
        if basename.startswith(("mistake_", "pattern_", "tech_", "tech-insight_", "architecture_")):
            target = "semantic/"
        elif basename.startswith("feedback_") or e["type"] in ("feedback", "user"):
            target = "personal/"
        elif basename.startswith(("project_",)) and e["age_days"] < 60:
            target = "episodic/"
        elif basename.startswith("reference_") or e["type"] == "reference":
            target = "personal/"
        if target:
            suggestions.append(f"- [`{e['path']}`]({e['path']}) → `{target}`")
    if suggestions:
        lines += suggestions[:25]
        if len(suggestions) > 25:
            lines.append(f"- … and {len(suggestions) - 25} more")
    else:
        lines.append("_Nothing flagged. Legacy dirs look settled or already promoted._")
    lines += [""]

    (REPORTS / "GRAPH_REPORT.md").write_text("\n".join(lines))


def write_dashboards(data: dict[str, Any]) -> None:
    REPORTS.mkdir(exist_ok=True)

    # stale-pages.md
    stale = sorted(data["stale"], key=lambda x: -x["age_days"])
    lines = [
        "# Stale Pages",
        "",
        f"Pages not modified in > 90 days. Generated by mem-compile at {time.strftime('%Y-%m-%d %H:%M')}.",
        "",
        "| Age (days) | Path | Description |",
        "| ---: | --- | --- |",
    ]
    for s in stale:
        desc = s["description"].replace("|", "\\|")[:100]
        lines.append(f"| {s['age_days']} | [{s['path']}]({s['path']}) | {desc} |")
    (REPORTS / "stale-pages.md").write_text("\n".join(lines) + "\n")

    # orphans.md
    lines = [
        "# Orphan Pages",
        "",
        f"Pages with zero inbound and zero outbound markdown links. Generated at {time.strftime('%Y-%m-%d %H:%M')}.",
        "",
    ]
    for o in sorted(data["orphans"]):
        lines.append(f"- [{o}]({o})")
    (REPORTS / "orphans.md").write_text("\n".join(lines) + "\n")

    # stats.md (human-readable overview)
    st = data["stats"]
    lines = [
        "# Memory Stats",
        "",
        f"Compiled: {time.strftime('%Y-%m-%d %H:%M')}",
        "",
        f"- **Total pages**: {st['total']}",
        f"- **By category**: " + ", ".join(f"{k}={v}" for k, v in sorted(st["by_category"].items())),
        f"- **With Related block**: {st['with_related_block']} ({100*st['with_related_block']//max(st['total'],1)}%)",
        f"- **Stale (>90d)**: {st['stale_count']}",
        f"- **Orphans (no links)**: {st['orphan_count']}",
        f"- **Avg inbound links**: {st['avg_inbound']}",
    ]
    (REPORTS / "stats.md").write_text("\n".join(lines) + "\n")

    # GRAPH_REPORT.md — auto-generated digest (link-graph only in v1)
    write_graph_report(data)


def main() -> int:
    CACHE.mkdir(exist_ok=True)
    data = collect()
    (CACHE / "agent-digest.json").write_text(json.dumps(data["entries"], ensure_ascii=False, indent=2))
    (CACHE / "index.json").write_text(json.dumps(data["index"], ensure_ascii=False, indent=2))
    (CACHE / "stats.json").write_text(json.dumps(data["stats"], ensure_ascii=False, indent=2))
    write_dashboards(data)
    st = data["stats"]
    print(f"[mem-compile] {st['total']} pages compiled")
    legacy = " ".join(f"{c}={st['by_category'].get(c,0)}" for c in ["entities","concepts","projects","feedback","reference"])
    tiers = " ".join(f"{c}={st['by_category'].get(c,0)}" for c in ["working","episodic","semantic","personal"])
    print(f"  legacy: {legacy}")
    print(f"  tiers:  {tiers}")
    print(f"  stale={st['stale_count']} orphans={st['orphan_count']} with_related={st['with_related_block']}")
    print(f"  digest: {CACHE/'agent-digest.json'} ({(CACHE/'agent-digest.json').stat().st_size} bytes)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
