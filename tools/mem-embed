#!/opt/homebrew/bin/python3.11
"""mem-embed — local embedding pipeline for mem-search.db vec layer.

Provides:
  mem-embed all                       Embed every .md file under memory/auto/**/
  mem-embed incremental               Embed only files whose mtime > vec_meta.embedded_at
  mem-embed file <path>               Embed a single file
  mem-embed query "<text>" [--k N]    Embed query, return top-K nearest chunks as TSV
  mem-embed status                    Print JSON status (model, dim, counts, timing)
  mem-embed drop                      DROP vec tables (rollback preparation)

Output of `query` (TSV, one row per hit):
  rank \t file_path \t chunk_type \t chunk_idx \t distance \t text_preview

Environment:
  MEM_DB_PATH      Override DB path (default ~/.claude-setup/tools/mem-search.db)
  MEM_CORPUS_PATH  Override corpus root (default ~/.claude-setup/memory/auto)
  MEM_MODEL        Override embedding model name
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sqlite3
import struct
import sys
import time
from pathlib import Path
from typing import Iterator, Literal, TypedDict

try:
    import sqlite_vec
except ImportError as e:
    print(f"mem-embed: sqlite-vec not installed: {e}", file=sys.stderr)
    print("  Fix: /opt/homebrew/bin/python3.11 -m pip install --user sqlite-vec==0.1.9", file=sys.stderr)
    sys.exit(2)

MODEL_NAME = os.environ.get("MEM_MODEL", "sentence-transformers/all-MiniLM-L6-v2")
DIM = 384
MEM_DIR = Path(os.environ.get("MEM_CORPUS_PATH", str(Path.home() / ".claude-setup" / "memory" / "auto")))
DB_PATH = Path(os.environ.get("MEM_DB_PATH", str(Path.home() / ".claude-setup" / "tools" / "mem-search.db")))

# Legacy flat dirs + new tier taxonomy. Matches mem-compile CATS.
CATS = [
    "entities", "concepts", "projects", "feedback", "reference",
    "working", "episodic", "semantic", "personal",
]
TIER_MARKERS = {"_tier.md", "_index.md"}

# Page format: frontmatter --- body --- "## Timeline" --- bullets
TRUTH_TIMELINE_SPLIT = re.compile(r"\n\n---\n\n## Timeline\s*\n", re.MULTILINE)
TIMELINE_BULLET_SPLIT = re.compile(r"\n(?=- \*\*\d{4}-\d{2}-\d{2})")


class Chunk(TypedDict):
    chunk_type: Literal["truth", "timeline"]
    chunk_idx: int
    text: str


def iter_memory_files(root: Path = MEM_DIR) -> Iterator[Path]:
    for cat in CATS:
        d = root / cat
        if not d.is_dir():
            continue
        for p in sorted(d.glob("*.md")):
            if p.name in TIER_MARKERS:
                continue
            yield p


def strip_frontmatter(raw: str) -> str:
    if not raw.startswith("---\n"):
        return raw
    end = raw.find("\n---\n", 4)
    if end < 0:
        return raw
    return raw[end + 5:]


class Chunker:
    """Split a page into truth chunk + per-timeline-entry chunks."""

    def chunk(self, raw: str) -> list[Chunk]:
        body = strip_frontmatter(raw)
        parts = TRUTH_TIMELINE_SPLIT.split(body, maxsplit=1)
        truth = parts[0].strip()
        chunks: list[Chunk] = []
        if truth:
            chunks.append({"chunk_type": "truth", "chunk_idx": 0, "text": truth})
        if len(parts) == 2:
            timeline = parts[1]
            bullets = TIMELINE_BULLET_SPLIT.split(timeline)
            for i, bullet in enumerate(bullets, start=1):
                t = bullet.strip()
                if t and t.startswith("-"):
                    chunks.append({"chunk_type": "timeline", "chunk_idx": i, "text": t})
        if not chunks:
            # Empty or unparseable page — embed whole body as truth to avoid losing it.
            chunks.append({"chunk_type": "truth", "chunk_idx": 0, "text": body.strip() or raw.strip()})
        return chunks


class Embedder:
    _model = None

    @classmethod
    def get(cls):
        if cls._model is None:
            from sentence_transformers import SentenceTransformer
            cls._model = SentenceTransformer(MODEL_NAME)
        return cls._model

    @classmethod
    def embed(cls, texts: list[str]) -> list[list[float]]:
        if not texts:
            return []
        m = cls.get()
        return m.encode(texts, normalize_embeddings=True, show_progress_bar=False).tolist()


def vec_to_bytes(vec: list[float]) -> bytes:
    return struct.pack(f"{len(vec)}f", *vec)


class VecDB:
    def __init__(self, path: Path = DB_PATH) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        self.conn = sqlite3.connect(str(path))
        self.conn.enable_load_extension(True)
        sqlite_vec.load(self.conn)
        self.conn.enable_load_extension(False)
        self.ensure_schema()

    def ensure_schema(self) -> None:
        c = self.conn
        c.execute(
            f"""
            CREATE VIRTUAL TABLE IF NOT EXISTS vec_chunks USING vec0(
                embedding float[{DIM}],
                +file_path TEXT,
                +chunk_type TEXT,
                +chunk_idx INTEGER,
                +text TEXT
            )
            """
        )
        c.execute(
            """
            CREATE TABLE IF NOT EXISTS vec_meta (
                file_path    TEXT PRIMARY KEY,
                mtime        REAL NOT NULL,
                embedded_at  REAL NOT NULL,
                chunk_count  INTEGER NOT NULL,
                model        TEXT NOT NULL,
                dim          INTEGER NOT NULL
            )
            """
        )
        c.execute(
            """
            CREATE TABLE IF NOT EXISTS vec_global (
                singleton          INTEGER PRIMARY KEY CHECK (singleton = 1),
                model              TEXT,
                dim                INTEGER,
                last_full_reindex  REAL,
                last_incremental   REAL,
                total_embed_ms     REAL DEFAULT 0,
                total_chunks_embed INTEGER DEFAULT 0
            )
            """
        )
        c.execute("INSERT OR IGNORE INTO vec_global (singleton) VALUES (1)")
        c.commit()

    def needs_reembed(self, file_path: Path) -> bool:
        row = self.conn.execute(
            "SELECT mtime, model, dim FROM vec_meta WHERE file_path = ?",
            (str(file_path),),
        ).fetchone()
        if not row:
            return True
        prev_mtime, prev_model, prev_dim = row
        if prev_model != MODEL_NAME or prev_dim != DIM:
            return True
        return file_path.stat().st_mtime > prev_mtime

    def delete_file(self, file_path: Path) -> None:
        self.conn.execute("DELETE FROM vec_chunks WHERE file_path = ?", (str(file_path),))
        self.conn.execute("DELETE FROM vec_meta WHERE file_path = ?", (str(file_path),))

    def replace_file(self, file_path: Path, chunks: list[Chunk], embeddings: list[list[float]]) -> None:
        self.delete_file(file_path)
        rows = [
            (vec_to_bytes(emb), str(file_path), ch["chunk_type"], ch["chunk_idx"], ch["text"])
            for ch, emb in zip(chunks, embeddings)
        ]
        self.conn.executemany(
            "INSERT INTO vec_chunks (embedding, file_path, chunk_type, chunk_idx, text) VALUES (?, ?, ?, ?, ?)",
            rows,
        )
        now = time.time()
        self.conn.execute(
            "INSERT OR REPLACE INTO vec_meta (file_path, mtime, embedded_at, chunk_count, model, dim) VALUES (?, ?, ?, ?, ?, ?)",
            (str(file_path), file_path.stat().st_mtime, now, len(chunks), MODEL_NAME, DIM),
        )

    def query(self, q_emb: list[float], k: int = 20) -> list[tuple[int, str, str, int, float, str]]:
        rows = self.conn.execute(
            """
            SELECT rank() OVER (ORDER BY distance) AS r, file_path, chunk_type, chunk_idx, distance,
                   substr(text, 1, 160) AS preview
            FROM vec_chunks
            WHERE embedding MATCH ? AND k = ?
            ORDER BY distance
            """,
            (vec_to_bytes(q_emb), k),
        ).fetchall()
        return rows

    def drop_all(self) -> None:
        c = self.conn
        c.execute("DROP TABLE IF EXISTS vec_chunks")
        c.execute("DROP TABLE IF EXISTS vec_meta")
        c.execute("DROP TABLE IF EXISTS vec_global")
        c.commit()

    def status(self) -> dict:
        c = self.conn
        files_embedded = c.execute("SELECT COUNT(*) FROM vec_meta").fetchone()[0]
        total_chunks = c.execute("SELECT COUNT(*) FROM vec_chunks").fetchone()[0]
        g = c.execute(
            "SELECT model, dim, last_full_reindex, last_incremental, total_embed_ms, total_chunks_embed FROM vec_global WHERE singleton=1"
        ).fetchone()
        model, dim, lfr, linc, tms, tcs = g or (None, None, None, None, 0, 0)
        avg_ms = (tms / tcs) if tcs else None
        return {
            "model": model or MODEL_NAME,
            "dim": dim or DIM,
            "files_embedded": files_embedded,
            "total_chunks": total_chunks,
            "last_full_reindex": _iso(lfr),
            "last_incremental": _iso(linc),
            "avg_embed_ms": round(avg_ms, 1) if avg_ms is not None else None,
        }

    def bump_timing(self, ms: float, chunk_count: int, *, incremental: bool = False, full: bool = False) -> None:
        c = self.conn
        now = time.time()
        if full:
            c.execute("UPDATE vec_global SET last_full_reindex=?, model=?, dim=? WHERE singleton=1", (now, MODEL_NAME, DIM))
        if incremental:
            c.execute("UPDATE vec_global SET last_incremental=? WHERE singleton=1", (now,))
        c.execute(
            "UPDATE vec_global SET total_embed_ms = total_embed_ms + ?, total_chunks_embed = total_chunks_embed + ? WHERE singleton=1",
            (ms, chunk_count),
        )

    def commit(self) -> None:
        self.conn.commit()

    def close(self) -> None:
        self.conn.close()


def _iso(ts: float | None) -> str | None:
    if not ts:
        return None
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(ts))


def _embed_one(db: VecDB, path: Path, chunker: Chunker) -> int:
    raw = path.read_text(encoding="utf-8", errors="replace")
    chunks = chunker.chunk(raw)
    if not chunks:
        return 0
    t0 = time.monotonic()
    embeddings = Embedder.embed([c["text"] for c in chunks])
    ms = (time.monotonic() - t0) * 1000.0
    db.replace_file(path, chunks, embeddings)
    db.bump_timing(ms, len(chunks))
    return len(chunks)


def cmd_all(args) -> int:
    db = VecDB()
    chunker = Chunker()
    t0 = time.monotonic()
    total_files = 0
    total_chunks = 0
    for path in iter_memory_files():
        n = _embed_one(db, path, chunker)
        total_files += 1
        total_chunks += n
    db.bump_timing(0, 0, full=True)
    db.commit()
    dur = time.monotonic() - t0
    print(f"[mem-embed] all: {total_files} files, {total_chunks} chunks in {dur:.1f}s", file=sys.stderr)
    db.close()
    return 0


def cmd_incremental(args) -> int:
    db = VecDB()
    chunker = Chunker()
    t0 = time.monotonic()
    changed = 0
    total_chunks = 0
    for path in iter_memory_files():
        if db.needs_reembed(path):
            n = _embed_one(db, path, chunker)
            changed += 1
            total_chunks += n
    db.bump_timing(0, 0, incremental=True)
    db.commit()
    dur = time.monotonic() - t0
    print(f"[mem-embed] incremental: {changed} files re-embedded, {total_chunks} chunks in {dur:.1f}s", file=sys.stderr)
    db.close()
    return 0


def cmd_file(args) -> int:
    path = Path(args.path).expanduser().resolve()
    if not path.exists():
        print(f"mem-embed: file not found: {path}", file=sys.stderr)
        return 1
    db = VecDB()
    n = _embed_one(db, path, Chunker())
    db.commit()
    print(f"[mem-embed] file: embedded {n} chunks for {path}", file=sys.stderr)
    db.close()
    return 0


def cmd_query(args) -> int:
    db = VecDB()
    # If vec table empty, return silently (hybrid fallback degrades to FTS5-only)
    status = db.status()
    if status["total_chunks"] == 0:
        db.close()
        return 0
    q_emb = Embedder.embed([args.text])[0]
    hits = db.query(q_emb, k=args.k)
    # Deduplicate by file_path — keep best (lowest distance) chunk per file.
    seen: dict[str, tuple[int, str, str, int, float, str]] = {}
    for row in hits:
        r, fp, ct, ci, d, pv = row
        if fp not in seen or d < seen[fp][4]:
            seen[fp] = (r, fp, ct, ci, d, pv)
    # Re-rank by distance after dedup.
    ordered = sorted(seen.values(), key=lambda x: x[4])
    for rank, (_, fp, ct, ci, d, pv) in enumerate(ordered[: args.k], start=1):
        # TSV: rank\tfile_path\tchunk_type\tchunk_idx\tdistance\tpreview
        pv_clean = pv.replace("\t", " ").replace("\n", " ")
        print(f"{rank}\t{fp}\t{ct}\t{ci}\t{d:.6f}\t{pv_clean}")
    db.close()
    return 0


def cmd_status(args) -> int:
    db = VecDB()
    s = db.status()
    print(json.dumps(s, indent=2))
    db.close()
    return 0


def cmd_drop(args) -> int:
    db = VecDB()
    db.drop_all()
    print("[mem-embed] dropped vec_chunks, vec_meta, vec_global", file=sys.stderr)
    db.close()
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(prog="mem-embed", description="Local embedding pipeline for mem-search hybrid retrieval")
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("all", help="Full re-embed of all memory files")
    sub.add_parser("incremental", help="Embed only files with changed mtime")
    f = sub.add_parser("file", help="Embed a single file")
    f.add_argument("path")
    q = sub.add_parser("query", help="Embed query text and return nearest neighbors")
    q.add_argument("text")
    q.add_argument("--k", type=int, default=20)
    sub.add_parser("status", help="Show vec layer status as JSON")
    sub.add_parser("drop", help="DROP vec tables (rollback)")
    args = ap.parse_args()
    return {
        "all": cmd_all,
        "incremental": cmd_incremental,
        "file": cmd_file,
        "query": cmd_query,
        "status": cmd_status,
        "drop": cmd_drop,
    }[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
