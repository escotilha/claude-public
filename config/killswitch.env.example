# Kill Switch Configuration
# Copy to ~/.killswitch.env and fill in values
# NEVER commit the filled-in version to git

# --- Contabo API (required) ---
# Get these from: https://my.contabo.com/api/details
CONTABO_CLIENT_ID=""
CONTABO_CLIENT_SECRET=""
CONTABO_API_USER=""        # Your Contabo login email
CONTABO_API_PASSWORD=""    # Your Contabo API password

# Instance ID — find with: killswitch --status (after setting creds above)
# Or from Contabo dashboard URL: https://my.contabo.com/compute/instances/{ID}
CONTABO_INSTANCE_ID=""

# --- Tailscale (optional) ---
# The kill switch uses the local `tailscale` CLI by default (no config needed).
# Only set these if you want API-based removal as a fallback.
TAILSCALE_VPS_IP="100.77.51.51"

# Optional: API key for device removal (tskey-api-*, NOT tskey-auth-*)
# Create at: https://login.tailscale.com/admin/settings/keys
# TAILSCALE_API_KEY=""
# TAILSCALE_DEVICE_ID=""
