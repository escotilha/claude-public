#!/usr/bin/env bash
#
# killswitch — Emergency VPS kill switch
#
# Stops the Contabo VPS at hypervisor level and removes it from Tailscale.
# Nothing running on the VPS can prevent this.
#
# Usage:
#   killswitch              # interactive confirmation
#   killswitch --force      # skip confirmation (for iOS Shortcuts)
#   killswitch --status     # check if VPS is running
#   killswitch --start      # restart the VPS after a kill
#
# Setup:
#   1. Copy .env.killswitch.example to ~/.killswitch.env
#   2. Fill in your Contabo API + Tailscale API credentials
#   3. Run: killswitch --status (to verify credentials work)
#

set -euo pipefail

# --- Config ---
ENV_FILE="${HOME}/.killswitch.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "ERROR: $ENV_FILE not found."
  echo "Copy the example and fill in your credentials:"
  echo "  cp $(dirname "$0")/../config/killswitch.env.example ~/.killswitch.env"
  exit 1
fi

# shellcheck source=/dev/null
source "$ENV_FILE"

# Validate required Contabo vars
for var in CONTABO_CLIENT_ID CONTABO_CLIENT_SECRET CONTABO_API_USER CONTABO_API_PASSWORD CONTABO_INSTANCE_ID; do
  if [[ -z "${!var:-}" ]]; then
    echo "ERROR: $var is not set in $ENV_FILE"
    exit 1
  fi
done

# Tailscale is optional — uses CLI if available, API key if configured
TAILSCALE_VPS_IP="${TAILSCALE_VPS_IP:-100.77.51.51}"
HAS_TAILSCALE_CLI=$(command -v tailscale >/dev/null 2>&1 && echo "yes" || echo "no")
HAS_TAILSCALE_API=$([[ -n "${TAILSCALE_API_KEY:-}" && -n "${TAILSCALE_DEVICE_ID:-}" ]] && echo "yes" || echo "no")

# --- Functions ---

get_contabo_token() {
  local token
  token=$(curl -s -X POST \
    "https://auth.contabo.com/auth/realms/contabo/protocol/openid-connect/token" \
    -d "client_id=${CONTABO_CLIENT_ID}" \
    -d "client_secret=${CONTABO_CLIENT_SECRET}" \
    -d "username=${CONTABO_API_USER}" \
    -d "password=${CONTABO_API_PASSWORD}" \
    -d "grant_type=password" \
    | python3 -c "import sys,json; print(json.load(sys.stdin)['access_token'])" 2>/dev/null)

  if [[ -z "$token" ]]; then
    echo "ERROR: Failed to get Contabo access token. Check credentials."
    exit 1
  fi
  echo "$token"
}

contabo_stop() {
  local token="$1"
  local request_id
  request_id=$(uuidgen)

  echo ">> Stopping VPS instance ${CONTABO_INSTANCE_ID}..."
  local response
  response=$(curl -s -w "\n%{http_code}" -X POST \
    "https://api.contabo.com/v1/compute/instances/${CONTABO_INSTANCE_ID}/actions/stop" \
    -H "Authorization: Bearer ${token}" \
    -H "x-request-id: ${request_id}" \
    -H "Content-Type: application/json")

  local http_code
  http_code=$(echo "$response" | tail -1)
  local body
  body=$(echo "$response" | sed '$d')

  if [[ "$http_code" =~ ^2 ]]; then
    echo "   VPS stop command sent successfully (HTTP ${http_code})"
  else
    echo "   WARNING: VPS stop returned HTTP ${http_code}"
    echo "   Response: ${body}"
  fi
}

contabo_start() {
  local token="$1"
  local request_id
  request_id=$(uuidgen)

  echo ">> Starting VPS instance ${CONTABO_INSTANCE_ID}..."
  local response
  response=$(curl -s -w "\n%{http_code}" -X POST \
    "https://api.contabo.com/v1/compute/instances/${CONTABO_INSTANCE_ID}/actions/start" \
    -H "Authorization: Bearer ${token}" \
    -H "x-request-id: ${request_id}" \
    -H "Content-Type: application/json")

  local http_code
  http_code=$(echo "$response" | tail -1)

  if [[ "$http_code" =~ ^2 ]]; then
    echo "   VPS start command sent successfully (HTTP ${http_code})"
  else
    echo "   WARNING: VPS start returned HTTP ${http_code}"
  fi
}

contabo_status() {
  local token="$1"
  local request_id
  request_id=$(uuidgen)

  local response
  response=$(curl -s \
    "https://api.contabo.com/v1/compute/instances/${CONTABO_INSTANCE_ID}" \
    -H "Authorization: Bearer ${token}" \
    -H "x-request-id: ${request_id}")

  local status
  status=$(echo "$response" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data'][0]['status'])" 2>/dev/null || echo "unknown")
  local name
  name=$(echo "$response" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data'][0]['name'])" 2>/dev/null || echo "unknown")
  local ip
  ip=$(echo "$response" | python3 -c "import sys,json; d=json.load(sys.stdin); ips=d['data'][0].get('ipConfig',{}).get('v4',{}).get('ip','unknown'); print(ips)" 2>/dev/null || echo "unknown")

  echo "VPS Status:"
  echo "  Name:     ${name}"
  echo "  ID:       ${CONTABO_INSTANCE_ID}"
  echo "  IP:       ${ip}"
  echo "  Status:   ${status}"
}

tailscale_remove() {
  echo ">> Removing VPS from Tailscale network..."

  if [[ "$HAS_TAILSCALE_CLI" == "yes" ]]; then
    # Use local tailscale CLI — no API key needed
    # Find the node ID by IP
    local node_id
    node_id=$(tailscale status --json 2>/dev/null \
      | python3 -c "
import sys,json
data=json.load(sys.stdin)
for nid,peer in data.get('Peer',{}).items():
  for addr in peer.get('TailscaleIPs',[]):
    if addr == '${TAILSCALE_VPS_IP}':
      print(nid)
      sys.exit(0)
print('')
" 2>/dev/null)

    if [[ -n "$node_id" ]]; then
      if tailscale lock remove "$node_id" 2>/dev/null; then
        echo "   VPS removed from Tailscale via CLI (node: ${node_id})"
      else
        # lock remove may not be available, try admin API via CLI
        echo "   Note: tailscale lock not enabled. VPS will lose Tailscale when powered off."
        echo "   To fully remove, visit: https://login.tailscale.com/admin/machines"
      fi
    else
      echo "   WARNING: Could not find VPS node (IP: ${TAILSCALE_VPS_IP}) in Tailscale"
    fi

  elif [[ "$HAS_TAILSCALE_API" == "yes" ]]; then
    # Fallback to API
    local response
    response=$(curl -s -w "\n%{http_code}" -X DELETE \
      "https://api.tailscale.com/api/v2/device/${TAILSCALE_DEVICE_ID}" \
      -u "${TAILSCALE_API_KEY}:")

    local http_code
    http_code=$(echo "$response" | tail -1)

    if [[ "$http_code" =~ ^2 ]]; then
      echo "   VPS removed from Tailscale (HTTP ${http_code})"
    else
      echo "   WARNING: Tailscale removal returned HTTP ${http_code}"
    fi

  else
    echo "   SKIP: No Tailscale CLI or API key configured."
    echo "   VPS will lose Tailscale connectivity when powered off anyway."
  fi
}

# --- Main ---

ACTION="${1:-kill}"

case "$ACTION" in
  --status|-s)
    echo "=== Kill Switch Status Check ==="
    token=$(get_contabo_token)
    contabo_status "$token"
    echo ""
    if [[ "$HAS_TAILSCALE_CLI" == "yes" ]]; then
      echo "Tailscale: CLI available (VPS IP: ${TAILSCALE_VPS_IP})"
    elif [[ "$HAS_TAILSCALE_API" == "yes" ]]; then
      echo "Tailscale: API configured (device: ${TAILSCALE_DEVICE_ID})"
    else
      echo "Tailscale: Not configured (VPS loses connectivity on power off anyway)"
    fi
    echo "Kill switch: READY"
    ;;

  --start)
    echo "=== Restarting VPS ==="
    token=$(get_contabo_token)
    contabo_start "$token"
    echo ""
    echo "Note: If Tailscale was removed during kill, you'll need to"
    echo "re-authorize at https://login.tailscale.com/admin/machines"
    echo "or SSH in via public IP (167.86.119.7:2222) to run 'tailscale up'."
    ;;

  --force|-f)
    echo "=== EMERGENCY KILL — NO CONFIRMATION ==="
    echo ""
    token=$(get_contabo_token)
    contabo_stop "$token"
    tailscale_remove
    echo ""
    echo "DONE. VPS is being shut down and removed from Tailscale."
    ;;

  --help|-h)
    echo "killswitch — Emergency VPS kill switch"
    echo ""
    echo "Usage:"
    echo "  killswitch              Kill VPS (with confirmation)"
    echo "  killswitch --force      Kill VPS (no confirmation, for automation)"
    echo "  killswitch --status     Check VPS status"
    echo "  killswitch --start      Restart VPS after a kill"
    echo "  killswitch --help       Show this help"
    ;;

  *)
    echo "=== VPS KILL SWITCH ==="
    echo ""
    token=$(get_contabo_token)
    contabo_status "$token"
    echo ""
    echo "This will:"
    echo "  1. STOP the VPS at hypervisor level (hard power off)"
    echo "  2. REMOVE the VPS from your Tailscale network"
    echo ""
    echo "Everything on the VPS will be killed immediately."
    echo ""
    read -rp "Type KILL to confirm: " confirm
    if [[ "$confirm" == "KILL" ]]; then
      echo ""
      contabo_stop "$token"
      tailscale_remove
      echo ""
      echo "DONE. VPS is being shut down and removed from Tailscale."
    else
      echo "Aborted."
    fi
    ;;
esac
